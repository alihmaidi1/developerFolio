COMPOSE_PROJECT_NAME=developerfolio

# Public app URL used by backend CORS. Use your real HTTPS domain in production.
PUBLIC_APP_URL=http://localhost:8080
# Bind to 127.0.0.1 when a host-level Nginx reverse proxy is already installed.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PUBLIC_PORT=8080
VITE_API_URL=/api

# External PostgreSQL database. Use a host reachable from the api container.
DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=developerfolio;Username=developerfolio;Password=replace-with-a-strong-database-password

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
HTTPS_USE_REDIRECTION=false

# JWT - JWT_KEY must be at least 32 characters.
JWT_ISSUER=DeveloperFolio.Api
JWT_AUDIENCE=DeveloperFolio.Admin
JWT_KEY=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRATION_MINUTES=60

# Initial admin account seeded on first startup.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace-with-a-strong-admin-password
