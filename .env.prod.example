COMPOSE_PROJECT_NAME=developerfolio

# ---- Shared Docker network -------------------------------------------------
# The network your EXISTING postgres + nginx containers already use.
# Find it:  docker inspect -f '{{json .NetworkSettings.Networks}}' <postgres-container>
EDGE_NETWORK=your-shared-network

# ---- Public URL (backend CORS) ---------------------------------------------
# Your real HTTPS domain, no trailing slash. Keep http:// only until TLS is on.
PUBLIC_APP_URL=https://your-domain.com

# ---- Published web port ----------------------------------------------------
# The host port the frontend is published on; your central nginx forwards here.
# Must be free on the host — pick one no other container/stack uses.
WEB_PUBLIC_PORT=8090

# ---- Database (your existing postgres container) ---------------------------
# Host = the postgres container's name/alias on EDGE_NETWORK.
# The database + user must already exist; the API creates the tables (migrations).
DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=developerfolio;Username=developerfolio;Password=REPLACE_STRONG_DB_PASSWORD

# ---- ASP.NET Core ----------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
# TLS is terminated at your nginx, so the API must NOT redirect to https.
HTTPS_USE_REDIRECTION=false

# ---- JWT (JWT_KEY must be >= 32 chars) -------------------------------------
JWT_ISSUER=DeveloperFolio.Api
JWT_AUDIENCE=DeveloperFolio.Admin
JWT_KEY=REPLACE_RANDOM_AT_LEAST_32_CHARACTERS
JWT_EXPIRATION_MINUTES=60

# ---- Initial admin (seeded on first startup) -------------------------------
ADMIN_SEED_EMAIL=you@your-domain.com
ADMIN_SEED_PASSWORD=REPLACE_STRONG_ADMIN_PASSWORD
