{
  "AllowedHosts": "*",
  "ConnectionStrings": {},
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "Key": "",
    "ExpirationMinutes": 60
  },
  "AdminSeed": {
    "Email": "",
    "Password": ""
  },
  "ImageStorage": {
    "MaxFileSizeBytes": 5242880,
    "AllowedContentTypes": [
      "image/png",
      "image/jpeg",
      "image/webp",
      "image/gif"
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Https": {
    "UseRedirection": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
